generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  auth0Id     String    @unique
  role        Role      @default(CANDIDATE)
  companyName String?   // Added to store Employer's company name
  profile     CandidateProfile?
  vacancies   Vacancy[] @relation("EmployerVacancies")
  messages    Message[] @relation("UserMessages")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  phoneAuth   UserAuth?
}

model UserAuth {
  id               String    @id @default(cuid())
  phone            String    @unique
  password         String
  otp              String?
  otpExpiresAt     DateTime?
  twoFactorSecret  String?
  isTwoFactorEnabled Boolean @default(false)
  pinCode          String?
  pinCodeExpiresAt DateTime?
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CandidateProfile {
  id             String        @id @default(cuid())
  fullName       String
  headline       String?
  phone          String?
  location       String?
  avatarUrl      String?
  linkedInUrl    String?
  githubUrl      String?
  resumeUrl      String?
  skills         String[]
  workExperience Json?
  education      Json?
  userId         String        @unique
  user           User          @relation(fields: [userId], references:[id], onDelete: Cascade)
  applications   Application[]
}

model Vacancy {
  id           String        @id @default(cuid())
  title        String
  company      String
  location     String
  salary       String
  type         String
  description  String
  skills       String[]
  employerId   String
  employer     User          @relation("EmployerVacancies", fields: [employerId], references: [id])
  applications Application[]
  questions    Question[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Question {
  id        String   @id @default(cuid())
  text      String
  options   String[]
  correct   String
  vacancyId String
  vacancy   Vacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
}

model Application {
  id          String            @id @default(cuid())
  status      ApplicationStatus @default(PENDING)
  coverLetter String?           @db.Text
  testScore   Int?
  aiScore     Int?              // Added for AI Semantic Ranking
  resumeUrl   String?
  candidateId String
  candidate   CandidateProfile  @relation(fields: [candidateId], references:[id], onDelete: Cascade)
  vacancyId   String
  vacancy     Vacancy           @relation(fields:[vacancyId], references: [id], onDelete: Cascade)
  messages    Message[]         @relation("ApplicationMessages")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Message {
  id            String      @id @default(cuid())
  content       String
  applicationId String
  application   Application @relation("ApplicationMessages", fields: [applicationId], references:[id], onDelete: Cascade)
  senderId      String
  sender        User        @relation("UserMessages", fields: [senderId], references:[id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

enum Role {
  CANDIDATE
  EMPLOYER
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}