generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  auth0Id      String            @unique 
  role         Role              @default(CANDIDATE)
  profile      CandidateProfile?
  vacancies    Vacancy[]         @relation("EmployerVacancies")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model CandidateProfile {
  id           String        @id @default(cuid())
  fullName     String
  resumeUrl    String?
  skills       String[]
  
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Vacancy {
  id          String      @id @default(cuid())
  title       String
  company     String
  location    String
  salary      String
  type        String
  description String
  skills      String[]

  employerId  String
  employer    User     @relation("EmployerVacancies", fields: [employerId], references: [id])
  
  applications Application[]
  questions    Question[]    // ADDED: Establishes relation to questions for the test

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// NEW MODEL: Stores questions for the competency test
model Question {
  id        String   @id @default(cuid())
  text      String
  options   String[] // Array of possible answers: ["Option A", "Option B"]
  correct   String   // The correct answer string: "Option B"
  
  vacancyId String
  vacancy   Vacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
}

model Application {
  id          String            @id @default(cuid())
  status      ApplicationStatus @default(PENDING)
  
  coverLetter String?           @db.Text
  testScore   Int?
  resumeUrl   String?           // ADDED: Path to the job-specific resume file

  candidateId String
  candidate   CandidateProfile  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  vacancyId   String
  vacancy     Vacancy           @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum Role {
  CANDIDATE
  EMPLOYER  
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}