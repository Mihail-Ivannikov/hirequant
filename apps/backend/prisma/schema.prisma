generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NO CHANGES TO THIS MODEL, EXCEPT ADDING THE RELATION
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  auth0Id   String    @unique
  role      Role      @default(CANDIDATE)
  profile   CandidateProfile?
  vacancies Vacancy[] @relation("EmployerVacancies")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // +++ ADD THIS ONE LINE TO CREATE THE LINK +++
  phoneAuth UserAuth?
}

// +++ NEW MODEL FOR MESSENGER AUTHENTICATION +++
model UserAuth {
  id        String   @id @default(cuid())
  phone     String   @unique // The unique identifier for the new system
  password  String   // Hashed password

  // One-Time Password (OTP) for verification
  otp          String?
  otpExpiresAt DateTime?

  // Two-Factor Authentication (2FA)
  twoFactorSecret    String?
  isTwoFactorEnabled Boolean  @default(false)

  // PIN Code for session re-validation
  pinCode          String?  // Hashed PIN
  pinCodeExpiresAt DateTime?

  // The one-to-one link to the core User model
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// --- YOUR EXISTING MODELS (UNCHANGED) ---

model CandidateProfile {
  id             String        @id @default(cuid())
  fullName       String
  headline       String?
  phone          String? // This is just profile data now, not for login. It's fine to keep it.
  location       String?
  avatarUrl      String?
  linkedInUrl    String?
  githubUrl      String?
  resumeUrl      String?
  skills         String[]
  workExperience Json?
  education      Json?
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications   Application[]
}

model Vacancy {
  id          String      @id @default(cuid())
  title       String
  company     String
  location    String
  salary      String
  type        String
  description String
  skills      String[]
  employerId  String
  employer    User        @relation("EmployerVacancies", fields: [employerId], references: [id])
  applications Application[]
  questions    Question[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Question {
  id        String   @id @default(cuid())
  text      String
  options   String[]
  correct   String
  vacancyId String
  vacancy   Vacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
}

model Application {
  id          String            @id @default(cuid())
  status      ApplicationStatus @default(PENDING)
  coverLetter String?           @db.Text
  testScore   Int?
  resumeUrl   String?
  candidateId String
  candidate   CandidateProfile  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  vacancyId   String
  vacancy     Vacancy           @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum Role {
  CANDIDATE
  EMPLOYER
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}